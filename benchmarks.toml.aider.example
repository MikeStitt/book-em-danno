# benchmarks.toml — the Aider Polyglot suite, all six languages.
#
# Auto-found next to danno.toml (or pass --benchmarks <path>). This file supplies
# the TASKS; the adjacent danno.toml supplies the MODEL matrix. `danno bench` runs
# the cross product: harnesses x models x tasks.
#
# These run the benchmark task *content* through danno's own execution model (one
# headless turn in a disposable sandbox, graded by the exercise's own tests under
# Aider's 2-attempt protocol) — NOT the official Docker-per-task harness, so the
# pass counts are danno capability signals, not official leaderboard scores.
# Unknown keys fail loud at load (config is code).

# Harnesses-under-test swept in one run; each gets its own <out>/<harness>/ tree
# plus a combined comparison report at the root. occ and claurst route to local
# Ollama; opencode runs the same models via the local relay. (Add "claude" only
# with a cloud danno.toml — the reference harness serves its own Anthropic model.)
harnesses = ["claude", "occ", "opencode", "claurst"]

# --- Runaway gates: per-cell BACKSTOPS, not fairness normalizers ----------------
# Set high enough that no legitimate solve trips them; they exist to kill a runaway
# (infinite tool-call loop, stuck stream). The harness's own step/turn cap is set to
# max_turns; an external watchdog hard-kills only at max_turns + max(3, 10%).
[gates]
max_turns  = 60          # Gate 1 — inference calls per cell (2-attempt aider fits well under)
max_tokens = 3_000_000   # Gate 2 — total tokens per cell
timeout_s  = 3600.0      # Gate 3 — wall-clock backstop; generous for slow local qwen on a Mac

# o4-mini is a fast paid cloud model: tighten its backstops so a loop can't run up
# either wall-clock or token cost. (Per-model key = the danno.toml [models] name.)
[gates.model."o4-mini"]
timeout_s  = 1200.0
max_tokens = 2_000_000

# --- Aider Polyglot -------------------------------------------------------------
# Self-contained Exercism exercises (stub + test files + instructions), one per
# "<language>/<slug>". danno seeds the whole exercise dir, prompts the agent, then
# builds+runs the exercise's own tests in the VM (restoring canonical test/editor
# files first, so an agent can't force a pass by editing a test). All six languages
# install their toolchain into the shell sandbox on first use.
#
#   TOOLCHAINS (auto-installed once per sandbox, egress union'd onto `balanced`):
#     python     pip pytest
#     go         go 1.23.4 tarball
#     rust       rustup stable (minimal)
#     cpp        apt cmake + g++ (Catch2 vendored per-exercise)
#     java       Amazon Corretto JDK 21 + gradle wrapper (JDK 25 breaks pinned Gradle 8.7)
#     javascript node/npm (base image) + per-exercise jest
[aider_polyglot]
enabled   = true
isolation = "shared"     # shared (default): one sandbox, pristine per-exercise re-seed | per-test
source    = "git:https://github.com/Aider-AI/polyglot-benchmark"
select = [
  # RANDOM order (deterministic shuffle of all 225 ids, seed 20260717), with three
  # manual swaps to front-load all six languages into the first 10:
  #   pos 8<->12 (javascript up), 9<->16 (python up), 10<->30 (cpp up).
  # NOT sorted by language or difficulty (no public per-exercise difficulty data
  # exists; see .docs/research-aider-polyglot-difficulty-by-test-case.md).
  # Regenerate: sort ids, random.Random(20260717).shuffle(ids), then apply the swaps.
  #
  # ---- first 10 uncommented: one of every language (py/go/rust/cpp/java/js) ----
  "java/satellite",
  "rust/gigasecond",
  "rust/nucleotide-codons",
  "rust/acronym",
  "rust/fizzy",
  "java/word-search",
  "go/hexadecimal",
