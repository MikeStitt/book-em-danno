# Maximal danno.toml — a test-only "kitchen-sink" fixture (NOT a shipped example).
#
# The shipped danno.toml.example is deliberately small for readability. This file
# exists so the test suite exercises, in a single load_config + render pass, the
# config surface that the small example does not: every implemented backend kind +
# the llamacpp stub, a `[[tools]]` block with BOTH install_to literals, a
# default_agent bound to a raw inline OpenCode ref (so the top-level `model` renders
# as that verbatim ref), agents mapping to a mix of [models] entries and a raw ref,
# and a non-default sandbox agent_home. See tests/test_loader.py and tests/test_generate.py.

[project]
target = "."

[defaults]
default_agent = "pm"               # -> a raw inline ref: top-level `model` is that ref verbatim
profile       = "hybrid"

[sandbox]
agent_home = "group:team-a"        # non-default agent_home (the keyword path is the small example)

# --- Backends: every implemented kind + the stub. llamacpp is declared but UNUSED so
#     render/generate still works (the stub raises only for a model actually ON a
#     llamacpp backend). Cloud models need no backend — see the raw ref in [agents]. ---
[backends.ollama]
kind           = "ollama"
base_url       = "http://host.docker.internal:11434/v1"

[backends.nvidia]                  # generic OpenAI-compatible endpoint (NVIDIA NIM)
kind        = "openai"
base_url    = "https://integrate.api.nvidia.com/v1"
api_key_env = "NVIDIA_API_KEY"     # emitted as {env:NVIDIA_API_KEY}; secret never written

[backends.llamacpp]                # declared but unused (stubbed runtime)
kind     = "llamacpp"
base_url = "http://host.docker.internal:8080/v1"

# --- Models on the two non-stub local/openai-compatible backends. context_budget and
#     output_limit are MODEL-level (required on ollama/openai models; forbidden on
#     inert/llamacpp). ---
[models.gemma3-27b]
backend          = "ollama"
tag              = "gemma3:27b"
context_budget   = 32000
output_limit     = 8192
reasoning_effort = "none"

[models.nemotron-ultra]
backend        = "nvidia"
tag            = "nvidia/nemotron-3-ultra-550b-a55b"
context_budget = 1000000
output_limit   = 8192

# Per-model escape hatch: raw keys deep-merged into this model's generated block for a
# harness. Here, an arbitrary opencode.jsonc model option danno does not otherwise model
# (reasoningEffort, if any, is preserved alongside).
[models.nemotron-ultra.overrides.opencode.options]
max_completion_tokens = 1000000

# Per-backend escape hatch: swap the provider's npm package (the native OpenAI SDK for an
# o-series endpoint, say), overriding danno's hardcoded @ai-sdk/openai-compatible.
[backends.nvidia.overrides.opencode]
npm = "@ai-sdk/openai"

# --- Agents: a raw inline cloud ref plus ollama and nvidia [models] entries. pm is
#     the default_agent. ---
[agents]
pm       = "anthropic/claude-sonnet-4-6"   # raw ref (contains "/") -> drives the top-level `model`
build    = "gemma3-27b"                    # ollama (local)
research = "nemotron-ultra"                # nvidia (openai-compatible)

# --- Tool catalog: IMPERATIVE installs. Both install_to literals so the loader
#     parses each (sandbox + project). ---
[[tools]]
name       = "ados"
source     = "https://github.com/juliusz-cwiakalski/agentic-delivery-os"
install_to = "sandbox"

[[tools]]
name       = "house-style"
source     = "https://example.com/house-style"
install_to = "project"

# --- OpenCode npm plugins: a bare one and a configured one with setup steps. ---
[[npm]]
package = "opencode-planner"

[[npm]]
package = "@plannotator/opencode@latest"
setup   = ["curl -fsSL https://plannotator.ai/install.sh | bash"]

[npm.config]
workflow       = "plan-agent"
planningAgents = ["plan"]

# --- Agent-general environment: KEY=value injected into the env-file of every
#     config-driven harness (opencode/claurst/occ — NOT claude). Values MAY embed
#     {env:VAR} host indirection, resolved at launch (see assemble_harness_env). ---
[env]
CLAUDE_CODE_API_TIMEOUT = "3600000"
NVIDIA_API_KEY          = "{env:NVIDIA_API_KEY}"
